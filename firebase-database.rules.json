{
  "rules": {
    ".read": false,
    ".write": false,
    "admin": {
      ".read": false,
      ".write": false,
      "hash": {
        ".read": true,
        ".write": true
      }
    },
    "provedores": {
      ".read": true,
      "$codigo": {
        ".write": true,
        "hosts": { "$index": { ".validate": "newData.isString() && newData.val().length <= 300" } },
        "auth_token": { ".validate": "newData.isString() || !newData.exists()" },
        "updatedAt": { ".validate": "newData.isString() || !newData.exists()" },
        "updated_at": { ".validate": "newData.isNumber() || !newData.exists()" },
        "deleted": { ".validate": "newData.isBoolean() || !newData.exists()" },
        "deletedAt": { ".validate": "newData.isString() || !newData.exists()" },
        "name": { ".validate": "newData.isString()" },
        "code": { ".validate": "newData.isString() || !newData.exists()" },
        "createdAt": { ".validate": "newData.isString() || !newData.exists()" },
        "$other": { ".validate": false }
      }
    },
    "app_config": {
      ".read": true,
      "update": {
        ".write": true,
        "version_code": { ".validate": "newData.isNumber()" },
        "version_name": { ".validate": "newData.isString()" },
        "download_url": { ".validate": "newData.isString()" },
        "force_update": { ".validate": "newData.isBoolean()" },
        "changelog": { ".validate": "newData.isString()" },
        "published_at": { ".validate": "newData.isNumber() || newData.isString()" },
        "$other": { ".validate": false }
      }
    },
    "profiles": {
      "$providerCode": {
        ".read": true,
        ".write": true,
        "$profileId": {
          "name": { ".validate": "newData.isString() && newData.val().length <= 30" },
          "avatar": { ".validate": "newData.isString()" },
          "createdAt": { ".validate": "newData.isString()" },
          "$other": { ".validate": false }
        }
      }
    },
    "watch_history": {
      "$providerCode": {
        "$profileId": {
          ".read": true,
          ".write": true,
          "$itemId": {
            "id": { ".validate": "newData.isString()" },
            "title": { ".validate": "newData.isString() && newData.val().length <= 200" },
            "type": { ".validate": "newData.isString()" },
            "icon": { ".validate": "newData.isString() || !newData.exists()" },
            "url": { ".validate": "newData.isString()" },
            "ext": { ".validate": "newData.isString() || !newData.exists()" },
            "watchedAt": { ".validate": "newData.isString()" },
            "progress": { ".validate": "newData.isNumber() || !newData.exists()" },
            "$other": { ".validate": false }
          }
        }
      }
    }
  }
}
